{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".electron-dist",
    "rootDir": "electron",
    "sourceMap": true
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["electron/**/__tests__/**/*.ts"]
}
