{
  "name": "yc-agents-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:start": "npm.cmd run build && npm.cmd run build:electron && electron . --disable-gpu --disable-gpu-compositing --disable-gpu-sandbox",
    "electron:dev": "npm.cmd run electron:start"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0",
    "typescript": "^5.5.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "lucide-react": "^0.468.0"
  },
  "main": ".electron-dist/main.js",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "electron": "^31.0.0",
    "jsdom": "^24.1.0",
    "vitest": "^2.0.0"
  }
}
