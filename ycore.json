{
  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-v4-flash",
        "fallbacks": [
          "deepseek/deepseek-v4-flash",
          "xiaomi/mimo-v2.5-pro"
        ]
      }
    },
    "entries": {
      "main": {
        "enabled": true
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com",
        "api": "openai-completions",
        "apiKeyEnv": "DEEPSEEK_API_KEY",
        "models": [
          {
            "id": "deepseek-v4-flash",
            "name": "deepseek-v4-flash",
            "contextWindow": 1000000,
            "maxOutputTokens": 4096,
            "request": {
              "max_tokens": 4096,
              "temperature": 0.2,
              "top_p": 0.95
            },
            "structuredOutput": {
              "enabled": true,
              "request": {
                "response_format": {
                  "type": "json_object"
                }
              }
            }
          }
        ]
      },
      "xiaomi": {
        "baseUrl": "https://api.xiaomimimo.com/v1",
        "api": "openai-completions",
        "apiKeyEnv": "MIMO_API_KEY",
        "models": [
          {
            "id": "mimo-v2.5-pro",
            "name": "MiMo V2.5 Pro",
            "contextWindow": 1000000,
            "maxOutputTokens": 4096,
            "request": {
              "max_completion_tokens": 4096,
              "temperature": 1.0,
              "top_p": 0.95
            },
            "structuredOutput": {
              "enabled": false,
              "request": {}
            }
          }
        ]
      }
    }
  },
  "skills": {
    "dirs": [
      "skills"
    ],
    "entries": {
      "code-review": {
        "enabled": true
      },
      "eval-writer": {
        "enabled": true
      },
      "ycore-analytics": {
        "enabled": true
      }
    }
  },
  "tools": {
    "profile": "coding",
    "entries": {
      "workspace_files": {"enabled": true},
      "file_reader": {"enabled": true},
      "workspace_write": {"enabled": true},
      "markdown_writer": {"enabled": true},
      "rag_search": {"enabled": true},
      "web_search": {"enabled": true},
      "git_inspector": {"enabled": true},
      "code_search": {"enabled": true},
      "verification_runner": {"enabled": true},
      "command_reader": {"enabled": true},
      "memory_search": {"enabled": true},
      "mcp_sqlite_list_tables": {"enabled": true},
      "mcp_sqlite_describe_table": {"enabled": true},
      "mcp_sqlite_query_readonly": {"enabled": true}
    },
    "web": {
      "search": {
        "provider": "tavily",
        "apiKeyEnv": "TAVILY_API_KEY"
      }
    }
  },
  "mcp": {
    "servers": {
      "filesystem": {
        "enabled": false,
        "description": "Local filesystem MCP boundary for future external server integration.",
        "type": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "."
        ]
      }
    }
  },
  "runtime": {
    "expectsJson": true,
    "toolCalling": "json-protocol",
    "modelTimeoutSeconds": 60,
    "maxToolCalls": 30,
    "toolTimeoutSeconds": 30,
    "invalidJsonRetryCount": 2,
    "providerRetryCount": 1,
    "providerRetryBackoffSeconds": 1,
    "toolExecutionRetryCount": 1,
    "verificationRetryCount": 1,
    "maxRecoveryAttempts": 4,
    "failOnInvalidJson": true
  },
  "analytics": {
    "enabled": true,
    "sqliteMcp": {
      "enabled": true
    },
    "fullText": false,
    "strict": false,
    "dbPath": null,
    "previewChars": 200,
    "maxRows": 100,
    "retentionRuns": 1000
  },
  "memory": {
    "enabled": true,
    "compressionThreshold": 12,
    "activeContextMaxTokens": 64000,
    "compactionTriggerPercent": 80,
    "compactionTargetPercent": 50,
    "retrieveTopK": 6,
    "retrievalTokenBudget": 4000,
    "minScore": 0.2,
    "sessionHalfLifeDays": 30,
    "embedding": {
      "enabled": false
    },
    "dream": {
      "enabled": false,
      "minSessions": 5,
      "minHours": 24,
      "maxInputTokens": 32000
    }
  }
}
